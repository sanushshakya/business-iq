# .gitignore
# Ignore all files in node_modules directory
node_modules/

# Ignore build output for React app
build/

# Ignore Python virtual environment
venv/
__pycache__/

# Ignore log files
*.log

# Ignore database files
db.sqlite3
db.sqlite3-journal

# Ignore Django development settings
local_settings.py

# Ignore static files generated by collectstatic
staticfiles/

# Ignore Docker-related files
docker-compose.yml
Dockerfile

# Ignore PyCharm project files
.idea/